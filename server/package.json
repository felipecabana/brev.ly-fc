{
  "name": "brevly-backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Brev.ly API — encurtador de URLs",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/main.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/main.js",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "node --env-file=.env node_modules/vitest/vitest.mjs run",
    "db:generate": "node --env-file=.env node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=.env node_modules/drizzle-kit/bin.cjs migrate"
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.2",
    "@types/supertest": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "supertest": "^7.1.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^3.2.4"
  }
}
